# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/techan?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars-change-in-production
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
# Comma-separated IPs to whitelist from rate limiting (optional)
RATE_LIMIT_WHITELIST=127.0.0.1

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_SECRET=your-cookie-secret-change-in-production
COOKIE_SECURE=false         
COOKIE_SAME_SITE=lax        

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Email (for password reset / verification) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM= 

# ─── Redis (optional — for distributed caching/throttle) ──────────────────────
REDIS_URL=redis://localhost:6379

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=
